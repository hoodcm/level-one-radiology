---
import Layout from '@/layouts/Layout.astro';
import Container from '@/components/layout/Container.astro';
import Grid from '@/components/layout/Grid.astro';
import Col from '@/components/layout/Col.astro';
import ArticleCard from '@/components/shared/ArticleCard.astro';
import { getArticles } from '@/lib/articles';

const articles = await getArticles();
---

<Layout
  title="Articles | Level One Radiology"
  description="All articles from Level One Radiology: clinical deep-dives, teaching cases, and commentary on emergency radiology."
>
  <section class="page">
    <Container>
      <header class="page-header">
        <p class="type-ui">Index</p>
        <h1 class="page-header__title">Articles</h1>
        <p class="page-header__meta type-meta">
          {articles.length} {articles.length === 1 ? 'article' : 'articles'}
        </p>
      </header>

      <Grid rowGap="var(--gap-md)">
        {articles.map((article) => (
          <Col span={{ md: 6, lg: 6 }} class="article-index__cell">
            <ArticleCard
              title={article.data.title}
              description={article.data.description}
              publishDate={article.data.publishDate}
              serial={article.data.serial}
              primaryTag={article.data.primaryTag}
              contentType={article.data.contentType}
              slug={article.id}
            />
          </Col>
        ))}
      </Grid>
    </Container>
  </section>
</Layout>
