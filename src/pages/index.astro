---
import Layout from '@/layouts/Layout.astro';
import Container from '@/components/layout/Container.astro';
import Grid from '@/components/layout/Grid.astro';
import Col from '@/components/layout/Col.astro';
import ArticleCard from '@/components/shared/ArticleCard.astro';
import DetectorHero from '@/components/shared/DetectorHero.astro';
import FeatureBand from '@/components/shared/FeatureBand.astro';
import { apparatus } from '@/lib/apparatus';
import { getArticles } from '@/lib/articles';

const allArticles = await getArticles();
const featuredArticles = allArticles.filter((a) => a.data.featured);

const leadArticle = featuredArticles[0];
const restArticles = featuredArticles.slice(1);

// Latest: everything outside the curated Featured block, newest first. The
// homepage surfaces new work on its own as it publishes, no featured flag
// required (Featured stays the editor's picks).
const latestArticles = allArticles.filter((a) => !a.data.featured);

// Hero statement — written once, rendered in two seats (hero h1 on the
// desktop composition; FeatureBand card h1 on the mobile composition).
const HERO_STATEMENT = 'An independent emergency radiology publication.';
const HERO_SUPPORT =
  'Clinical deep-dives, teaching cases, and field notes from a practicing radiologist.';
---

<Layout title="Level One Radiology: Independent Emergency Radiology">
  <!-- Hero field: one wrapper over hero + feature band so the blueprint grid
       (.hero-field--detector::before, homepage.css) runs continuously behind
       both — the expanding card covers the same hairlines the hero shows. -->
  <div class:list={['hero-field', apparatus.detectorHero && 'hero-field--detector']}>
  <!-- Hero -->
  <section class={apparatus.detectorHero ? 'hero hero--detector' : 'hero'}>
    {apparatus.detectorHero && <DetectorHero />}
    <Container>
      {
        apparatus.detectorHero ? (
          <!-- Detector composition: copy rides the slab band. The wordmark
               shows at every width; the arrangement (and the h1's active seat,
               here vs the FeatureBand card) switches on the shared viewport
               predicate — the same one the drawing uses. -->
          <div class="hero-copy">
            <a href="/" class="hero__wordmark" aria-label="Level One Radiology, home">
              <span class="hero__wordmark-line"><span class="hero__wordmark-level">Level One</span></span>
              <span class="hero__wordmark-line"><span class="hero__wordmark-radiology">Radiology</span></span>
            </a>
            <h1 class="hero__tagline">
              <span class="hero__statement">{HERO_STATEMENT}</span>
              <span class="hero__support">{HERO_SUPPORT}</span>
            </h1>
          </div>
        ) : (
          <>
            <!-- Brand wordmark, mobile only; on desktop the header carries it. -->
            <a href="/" class="hero__wordmark" aria-label="Level One Radiology, home">
              <span class="hero__wordmark-line"><span class="hero__wordmark-level">Level One</span></span>
              <span class="hero__wordmark-line"><span class="hero__wordmark-radiology">Radiology</span></span>
            </a>
            <!-- One h1, two voices: on mobile the spans flow as a single quiet
                 paragraph under the wordmark; on desktop (no wordmark in the hero)
                 the statement steps up to display scale as the page's opening moment. -->
            <h1 class="hero__tagline">
              <span class="hero__statement">{HERO_STATEMENT}</span>
              <span class="hero__support">{HERO_SUPPORT}</span>
            </h1>
          </>
        )
      }
    </Container>
  </section>

  <!-- Signature full-bleed feature band (expands on scroll). On the mobile
       detector composition it carries the hero statement as the page h1. -->
  <FeatureBand statement={HERO_STATEMENT} support={HERO_SUPPORT} />
  </div>

  <!-- Featured Content -->
  {featuredArticles.length > 0 && (
    <section class="featured-section">
      <Container>
        <div class="featured-section__header">
          <h2 class="type-ui">Featured</h2>
        </div>
        <Grid>
          {leadArticle && (
            <Col span={{ lg: 11 }}>
              <ArticleCard
                featured
                title={leadArticle.data.title}
                description={leadArticle.data.description}
                publishDate={leadArticle.data.publishDate}
                primaryTag={leadArticle.data.primaryTag}
                contentType={leadArticle.data.contentType}
                slug={leadArticle.id}
              />
            </Col>
          )}
          <Col span={{ lg: 7 }} class="featured-grid__rest">
            {restArticles.map((article) => (
              <ArticleCard
                title={article.data.title}
                description={article.data.description}
                publishDate={article.data.publishDate}
                primaryTag={article.data.primaryTag}
                contentType={article.data.contentType}
                slug={article.id}
              />
            ))}
          </Col>
        </Grid>
      </Container>
    </section>
  )}

  <!-- Latest — chronological feed of everything outside Featured -->
  {latestArticles.length > 0 && (
    <section class="latest-section">
      <Container>
        <div class="latest-section__header">
          <h2 class="type-ui">Latest</h2>
          <a href="/articles/" class="latest-section__all">All articles →</a>
        </div>
        <Grid rowGap="var(--gap-md)">
          {latestArticles.map((article) => (
            <Col span={{ md: 6, lg: 6 }}>
              <ArticleCard
                title={article.data.title}
                description={article.data.description}
                publishDate={article.data.publishDate}
                primaryTag={article.data.primaryTag}
                contentType={article.data.contentType}
                slug={article.id}
              />
            </Col>
          ))}
        </Grid>
      </Container>
    </section>
  )}
</Layout>
