---
import Layout from '@/layouts/Layout.astro';
import Container from '@/components/layout/Container.astro';
---

<Layout title="404 | Level One Radiology" description="Page not found.">
  <section class="page">
    <Container width="reading">
      <div class="not-found">
        <p class="type-ui">No signal</p>
        <h1 class="not-found__code">404</h1>
        <p class="not-found__text">
          This page doesn't exist. Check the address, or start from one of the pages below.
        </p>
        <nav class="not-found__links" aria-label="Recovery">
          <a href="/" class="article__back">← Home</a>
          <a href="/articles" class="article__back">Browse articles</a>
        </nav>
      </div>
    </Container>
  </section>
</Layout>
