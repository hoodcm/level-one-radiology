---
import Container from '@/components/layout/Container.astro';

// Production builds emit directory URLs ('/about/'); dev serves '/about'.
// Normalize before comparing or the active state never matches in prod.
const current = Astro.url.pathname.replace(/\/+$/, '') || '/';

const navItems: { href: string; label: string; active: boolean }[] = [
  { href: '/articles/', label: 'Articles', active: current.startsWith('/articles') },
  { href: '/about/', label: 'About', active: current === '/about' },
];
---

<header class="site-header" data-site-header>
  <Container class="site-header__inner">
    <a href="/" class="site-logo" aria-label="Level One Radiology, home">
      <!-- Mobile: icon mark -->
      <svg class="site-logo__mark" viewBox="0 0 439 522" fill="currentColor" aria-hidden="true" focusable="false">
        <path d="M0.251099 393L105.568 0H209.913L132.746 287.956H238.251L210.101 393H0.251099Z" />
        <path d="M438.251 129L332.935 522H228.589L305.756 234.044H200.251L228.401 129L438.251 129Z" />
      </svg>
      <!-- Desktop: wordmark -->
      <span class="site-logo__wordmark" aria-hidden="true">
        <span class="site-logo__level-one">Level One</span> <span class="site-logo__radiology">Radiology</span>
      </span>
    </a>

    <!-- Desktop nav -->
    <nav class="site-nav" aria-label="Main navigation">
      <ul class="site-nav__list">
        {navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={["site-nav__item", { "site-nav__item--active": item.active }]}
            >
              {item.label}
            </a>
          </li>
        ))}
        <li>
          <a href="#subscribe" class="site-nav__item site-nav__item--cta">Subscribe</a>
        </li>
      </ul>
    </nav>

    <!-- Mobile hamburger -->
    <button
      class="nav-toggle"
      type="button"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-nav-toggle
    >
      <span class="nav-toggle__bars" aria-hidden="true">
        <span class="nav-toggle__line"></span>
        <span class="nav-toggle__line"></span>
        <span class="nav-toggle__line"></span>
      </span>
    </button>
  </Container>
</header>

<!-- Full-screen mobile overlay menu, sibling of the header so its fixed
     positioning resolves against the viewport, not the backdrop-filtered bar. -->
<nav class="mobile-menu" id="mobile-menu" aria-label="Mobile navigation" data-mobile-menu>
  <ul class="mobile-menu__list">
    {navItems.map((item) => (
      <li>
        <a
          href={item.href}
          class:list={["mobile-menu__item", { "is-active": item.active }]}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ul>
  <a href="#subscribe" class="mobile-menu__cta">Subscribe</a>
</nav>

<script>
  const root = document.documentElement;
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');

  // Desktop wordmark → icon-mark collapse: flag once the page scrolls past a
  // small threshold. rAF-throttled, passive. CSS owns the actual crossfade.
  const SCROLL_THRESHOLD = 32;
  let ticking = false;
  const syncScrolled = () => {
    root.classList.toggle('is-scrolled', window.scrollY > SCROLL_THRESHOLD);
    ticking = false;
  };
  window.addEventListener(
    'scroll',
    () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(syncScrolled);
      }
    },
    { passive: true }
  );
  syncScrolled();

  // Measure the wordmark's rendered width so the desktop shrink-collapse can
  // animate width → 0 cleanly (no max-width guesswork). Re-measured after fonts
  // load and on resize; the value is read by CSS as `--wordmark-w`.
  const logo = document.querySelector<HTMLElement>('.site-logo');
  const wordmark = document.querySelector<HTMLElement>('.site-logo__wordmark');
  const desktop = window.matchMedia('(min-width: 48em)');
  const measureWordmark = () => {
    if (!logo || !wordmark || !desktop.matches) return;
    const w = Math.ceil(wordmark.getBoundingClientRect().width || wordmark.scrollWidth);
    if (w > 0) logo.style.setProperty('--wordmark-w', `${w}px`);
  };
  if (document.fonts?.ready) {
    document.fonts.ready.then(measureWordmark);
  } else {
    measureWordmark();
  }
  // rAF-throttled: resize fires per event and measureWordmark forces layout.
  let measuring = false;
  window.addEventListener('resize', () => {
    if (!measuring) {
      measuring = true;
      requestAnimationFrame(() => {
        measureWordmark();
        measuring = false;
      });
    }
  });
  desktop.addEventListener('change', measureWordmark);

  if (toggle) {
    const setOpen = (open: boolean) => {
      root.classList.toggle('is-nav-open', open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    };

    toggle.addEventListener('click', () => {
      setOpen(!root.classList.contains('is-nav-open'));
    });

    // Close when a destination is chosen or on Escape.
    document.querySelectorAll('[data-mobile-menu] a').forEach((link) =>
      link.addEventListener('click', () => setOpen(false))
    );
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setOpen(false);
    });
  }
</script>
