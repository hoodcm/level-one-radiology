---
/**
 * Container — the page shell: caps width, centers, applies the page margin
 * (page edge → content). Replaces hand-rolled `max-width + margin:auto +
 * padding` blocks.
 *
 *   page    → full page shell, capped at --grid-max-width (1440px)
 *   media   → figures / media / code, content measure --media-column (880px)
 *   reading → long-form prose, content measure --reading-column (640px)
 *
 * `media`/`reading` are *content measures*: the page margin is added back into
 * the cap (calc) so the actual content width equals the token (640/880px),
 * matching the existing `.reading-column`/`.media-column` inner wrappers. `page`
 * is a shell max: its content is the cap minus margins, as before the migration.
 */
interface Props {
  width?: 'page' | 'media' | 'reading';
  class?: string;
}
const { width = 'page', class: className } = Astro.props;
const widthVar = {
  page: 'var(--grid-max-width)',
  media: 'calc(var(--media-column) + 2 * var(--grid-margin))',
  reading: 'calc(var(--reading-column) + 2 * var(--grid-margin))',
}[width];
---

<div class:list={['l1-container', className]} style={`--_container-width: ${widthVar};`}>
  <slot />
</div>

<style>
  .l1-container {
    max-width: var(--_container-width);
    margin-inline: auto;
    padding-inline: var(--grid-margin);
    width: 100%;
  }
</style>
