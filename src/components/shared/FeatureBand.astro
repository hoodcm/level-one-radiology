---
// Full-bleed feature band: the homepage's one signature scroll moment.
// A plain contained card on black that WIDENS edge-to-edge as it scrolls up
// the viewport. The widen is a progressive enhancement (the component's
// script below drives it) — without JS or under prefers-reduced-motion the
// card simply sits contained.
//
// Detector hero (apparatus.detectorHero): on the mobile composition the hero
// statement lives HERE — the card carries the page h1 (statement + support,
// passed in by index.astro) plus the gold subscribe route (the keystone-metric
// action, above the fold on mobile), shown only when the shared composition
// predicate reads mobile (homepage.css gates it). Without copy the band is
// purely decorative (aria-hidden).
import { apparatus } from '@/lib/apparatus';

interface Props {
  statement?: string;
  support?: string;
}
const { statement, support } = Astro.props;
const carriesCopy = apparatus.detectorHero && statement;
---

<section class="feature-band" aria-hidden={carriesCopy ? undefined : 'true'}>
  <div class="feature-band__surface">
    {carriesCopy && (
      <div class="feature-band__copy">
        <h1 class="feature-band__heading">
          <span class="feature-band__statement">{statement}</span>
          <span class="feature-band__support">{support}</span>
        </h1>
        <a href="#subscribe" class="feature-band__cta">Subscribe</a>
      </div>
    )}
  </div>
</section>

<script>
  // Widen — scroll-LINKED, not auto: `--fb-progress` (0→1) tracks how far the
  // card has scrolled up the viewport, so the card only reaches the edges once
  // most of it is on screen. Without JS / under reduced motion this script
  // never runs and the card stays contained.
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
  const band = document.querySelector<HTMLElement>('.feature-band__surface');

  if (band && !reduce.matches) {
    let lastProgress = '';
    const update = () => {
      const rect = band.getBoundingClientRect();
      const vh = window.innerHeight || 1;
      // Contained (page-width gutters) at the rest/peek position, widening to
      // full-bleed as you scroll the card up, reaching p=1 once it nears the
      // top of the viewport. p=0 anchors at the card's own rest line — its
      // document offset, i.e. where its top sits at scrollY 0 — capped at the
      // classic 70% line so a tall hero keeps the old dead zone. A fixed 70%
      // start alone pre-fired the expansion on the mobile detector
      // composition, whose shorter hero rests the card above that line.
      const rest = rect.top + window.scrollY;
      const start = Math.min(rest, vh * 0.7);
      const end = vh * 0.1;
      const p = Math.max(0, Math.min(1, (start - rect.top) / (start - end)));
      // p is pinned at 0 or 1 for most of the page's scroll range — skip the
      // style write (and its invalidation) when the value hasn't changed.
      const next = p.toFixed(4);
      if (next !== lastProgress) {
        band.style.setProperty('--fb-progress', next);
        lastProgress = next;
      }
    };

    let ticking = false;
    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(() => {
          update();
          ticking = false;
        });
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }
  // Reduced motion / no JS: never armed — the static composition shows as-is.
</script>
