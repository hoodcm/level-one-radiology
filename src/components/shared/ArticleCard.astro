---
import Tag from '@/components/shared/Tag.astro';
import {
  tagVariant,
  contentTypeVariant,
  contentTypeLabel,
  type PrimaryTag,
  type ContentType,
} from '@/lib/tags';

interface Props {
  title: string;
  description: string;
  publishDate: Date;
  primaryTag: PrimaryTag;
  contentType: ContentType;
  slug: string;
  /** Lead treatment: larger title, generous padding, fills its grid cell. */
  featured?: boolean;
}

const { title, description, publishDate, primaryTag, contentType, slug, featured = false } =
  Astro.props;

// Frontmatter dates parse as UTC midnight; render in UTC too, or the
// calendar date shifts back a day in US timezones.
const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
  timeZone: 'UTC',
});

// Shared with the article h1 so the title morphs across the navigation
// (cross-document view transitions). Must be a valid CSS custom-ident.
const vtName = `vt-${slug.replace(/[^a-zA-Z0-9-]/g, '-')}`;
---

<a href={`/articles/${slug}/`} class:list={['article-card', { 'article-card--lead': featured }]}>
  <div class="article-card__tags">
    <Tag label={primaryTag.toUpperCase()} variant={tagVariant(primaryTag)} />
    <Tag label={contentTypeLabel(contentType)} variant={contentTypeVariant(contentType)} />
  </div>
  <h3 class="article-card__title" style={`view-transition-name: ${vtName};`}>{title}</h3>
  <p class="article-card__excerpt">{description}</p>
  <div class="article-card__meta">
    <span>{formattedDate}</span>
  </div>
</a>
