---
/**
 * TableOfContents — the article's h2 section index, in two variants:
 *
 * - `rail` (default): the "On this page" rail beside the reading column.
 *   Visible only ≥80em; a scroll-spy in [slug].astro stamps aria-current.
 * - `index`: the mobile INDEX — a mono <details> disclosure under the article
 *   header, visible <80em (apparatus/article-index.css). Gated by the
 *   `apparatus.mobileToc` kill switch, so disabling emits no markup.
 *
 * Both render only when the article has 2+ sections, and both number their
 * entries to mirror the CSS section ordinals on the prose h2s.
 */
import { apparatus } from '@/lib/apparatus';

interface Props {
  headings: { depth: number; slug: string; text: string }[];
  variant?: 'rail' | 'index';
}
const { headings, variant = 'rail' } = Astro.props as Props;
// Astro collects heading text after rehype runs, so the appended anchor "#"
// (rehype-autolink-headings) rides along — strip it.
const sections = headings
  .filter((h) => h.depth === 2)
  .map((h) => ({ ...h, text: h.text.replace(/#\s*$/, '') }));
---

{variant === 'rail' && sections.length >= 2 && (
  <nav class="toc article__toc" aria-label="On this page" data-toc>
    <p class="type-ui">On this page</p>
    <ol class="toc__list">
      {sections.map((section) => (
        <li class="toc__item">
          <a href={`#${section.slug}`} class="toc__link">{section.text}</a>
        </li>
      ))}
    </ol>
  </nav>
)}

{variant === 'index' && apparatus.mobileToc && sections.length >= 2 && (
  <div class="reading-column">
    <details class="article-index">
      <summary class="article-index__summary">Index</summary>
      <ol class="article-index__list">
        {sections.map((section) => (
          <li class="article-index__item">
            <a href={`#${section.slug}`} class="article-index__link">{section.text}</a>
          </li>
        ))}
      </ol>
    </details>
  </div>
)}
