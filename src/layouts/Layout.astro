---
import '@/styles/main.css';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  /** Article pages pass 'article' + publishDate so shares/crawlers see them as posts. */
  ogType?: 'website' | 'article';
  publishedTime?: Date;
}

const {
  title,
  description = 'Independent emergency radiology publication combining the timeliness of Radiology Business with the educational rigor of RadioGraphics.',
  ogImage = '/images/og-default.jpg',
  ogType = 'website',
  publishedTime,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    {publishedTime && (
      <meta property="article:published_time" content={publishedTime.toISOString()} />
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Feed autodiscovery — lets readers paste the bare domain into a feed app. -->
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Level One Radiology"
      href={new URL('rss.xml', Astro.site)}
    />

    <!-- Mobile browser chrome merges with the canvas. Mirrors
         --color-bg-deepest (metas can't read CSS vars). -->
    <meta name="theme-color" content="#0B0A08" />

    <!-- Preload the above-the-fold faces (the ACTIVE trial faces — Newsreader
         serif, DM Sans body, Michroma brand/UI) so first paint doesn't
         swap-reflow the hero. Self-hosted variable woff2, latin subset; see
         scripts/fetch-ofl-fonts.mjs. -->
    <link rel="preload" href="/fonts/ofl/newsreader-roman-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/ofl/dm-sans-roman-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/ofl/michroma-roman-latin.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Scroll-into-view reveals. Toggles `is-revealed` on entry AND exit so
      // reveals reverse on the way back out (Anthropic's signature). CSS owns
      // the transition and the prefers-reduced-motion opt-out.
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
      const els = document.querySelectorAll<HTMLElement>('[data-reveal], [data-expand]');
      if (els.length && !reduce.matches && 'IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              entry.target.classList.toggle('is-revealed', entry.isIntersecting);
            }
          },
          { threshold: 0.15, rootMargin: '0px 0px -10% 0px' }
        );
        els.forEach((el) => io.observe(el));
      } else {
        // No IntersectionObserver / reduced motion: show everything immediately.
        els.forEach((el) => el.classList.add('is-revealed'));
      }
    </script>
  </body>
</html>
